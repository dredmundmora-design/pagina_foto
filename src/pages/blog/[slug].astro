---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const entradas = await getCollection("blog");
  return entradas.map((entrada) => ({
    params: { slug: entrada.id },
    props: { entrada },
  }));
}

const { entrada } = Astro.props;
const { Content } = await render(entrada);
---

<Layout title={entrada.data.titulo}>
  <article class="container post">
    <a href="/blog" class="mono-label back-link">← Blog</a>
    <span class="mono-label">
      {entrada.data.fecha.toLocaleDateString("es-MX", {
        year: "numeric",
        month: "long",
        day: "numeric",
      })}
    </span>
    <h1>{entrada.data.titulo}</h1>
    <div class="post__content">
      <Content />
    </div>
  </article>

  <style>
    .post {
      padding-top: var(--space-lg);
      padding-bottom: var(--space-xl);
      max-width: 720px;
    }
    .back-link {
      display: block;
      margin-bottom: var(--space-sm);
    }
    .post h1 {
      margin-top: var(--space-xs);
      margin-bottom: var(--space-md);
    }
    .post__content {
      font-size: 1.05rem;
      line-height: 1.75;
    }
    .post__content :global(img) {
      display: block;
      width: calc(100% + 4rem);
      margin-left: -2rem;
      margin-top: var(--space-lg);
      margin-bottom: var(--space-xs);
      max-width: none;
    }
    .post__content :global(p:has(img)) {
      margin-bottom: 0;
    }
    @media (max-width: 640px) {
      .post__content :global(img) {
        width: 100%;
        margin-left: 0;
      }
    }
    .post__content :global(p) {
      margin-bottom: var(--space-sm);
    }
    .post__content :global(img) {
      display: block;
      width: calc(100% + 4rem);
       height: auto;
      margin-left: -2rem;
      margin-top: var(--space-lg);
      margin-bottom: var(--space-xs);
      max-width: none;
    }
    .post__content :global(p:has(img)) {
      margin-bottom: 0;
    }
    .post__content :global(p:has(> em:only-child)) {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      font-style: normal;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--color-grey-600);
      margin-top: 0;
      margin-bottom: var(--space-md);
    }
    .post__content :global(p:has(> em:only-child) em) {
      font-style: normal;
    }
    @media (max-width: 640px) {
      .post__content :global(img) {
        width: 100%;
        margin-left: 0;
      }
    }
  </style>
</Layout>