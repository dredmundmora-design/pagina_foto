---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const series = (await getCollection("series")).sort(
  (a, b) => (a.data.orden ?? 0) - (b.data.orden ?? 0)
);
---

<Layout title="Portafolio">
  <section class="container portfolio-header">
    <h1>Portafolio</h1>
  </section>

  <section class="container series-grid">
    {series.map((s, i) => (
      <a href={`/portafolio/${s.id}`} class="series-card">
        <div class="series-card__placeholder">
          <span class="mono-label">N.° {String(i + 1).padStart(3, "0")}</span>
        </div>
        <h2>{s.data.titulo}</h2>
        <span class="mono-label">{s.data.año}</span>
      </a>
    ))}
  </section>

  <style>
    .portfolio-header {
      padding-top: var(--space-lg);
      padding-bottom: var(--space-sm);
    }
    .series-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: var(--space-md);
      padding-top: var(--space-md);
      padding-bottom: var(--space-xl);
    }
    .series-card {
      display: block;
    }
    .series-card__placeholder {
      aspect-ratio: 4 / 5;
      background: var(--color-grey-200);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: var(--space-xs);
    }
    .series-card h2 {
      margin-top: var(--space-xs);
    }
  </style>
</Layout>