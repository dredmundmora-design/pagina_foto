---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

const series = (await getCollection("series")).sort(
  (a, b) => (a.data.orden ?? 0) - (b.data.orden ?? 0)
);

const todasLasImagenes = import.meta.glob<{ default: ImageMetadata }>(
  "../../assets/**/*.{jpeg,jpg,JPG,JPEG,png,PNG,webp,WEBP}"
);

async function obtenerPortada(slug: string) {
  const carpeta = `../../assets/${slug}/`;
  const ruta = Object.keys(todasLasImagenes)
    .filter((r) => r.startsWith(carpeta))
    .sort()[0];
  if (!ruta) return null;
  const mod = await todasLasImagenes[ruta]();
  return mod.default;
}

const portadas = await Promise.all(series.map((s) => obtenerPortada(s.id)));
---

<Layout title="Portafolio">
  <section class="container portfolio-header">
    <h1>Portafolio</h1>
  </section>

  <section class="container series-grid">
    {series.map((s, i) => (
      <a href={`/portafolio/${s.id}`} class="series-card">
        <div class="series-card__placeholder">
          {portadas[i] ? (
            <Image
              src={portadas[i]}
              alt={s.data.titulo}
              class="series-card__img"
            />
          ) : (
            <span class="mono-label">N.° {String(i + 1).padStart(3, "0")}</span>
          )}
        </div>
        <h2>{s.data.titulo}</h2>
        <span class="mono-label">{s.data.año}</span>
      </a>
    ))}
  </section>

  <style>
    .portfolio-header {
      padding-top: var(--space-lg);
      padding-bottom: var(--space-sm);
    }
    .series-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: var(--space-md);
      padding-top: var(--space-md);
      padding-bottom: var(--space-xl);
    }
    .series-card {
      display: block;
    }
    .series-card__placeholder {
      aspect-ratio: 4 / 5;
      background: var(--color-grey-200);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: var(--space-xs);
      overflow: hidden;
    }
    .series-card__img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: opacity 0.2s;
    }
    .series-card:hover .series-card__img {
      opacity: 0.85;
    }
    .series-card h2 {
      margin-top: var(--space-xs);
    }
  </style>
</Layout>