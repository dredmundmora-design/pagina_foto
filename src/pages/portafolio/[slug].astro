---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

export async function getStaticPaths() {
  const series = await getCollection("series");
  return series.map((serie) => ({
    params: { slug: serie.id },
    props: { serie },
  }));
}

const { serie } = Astro.props;
const { Content } = await render(serie);

const todasLasImagenes = import.meta.glob<{ default: ImageMetadata }>(
  "../../assets/**/*.{jpeg,jpg,JPG,JPEG,png,PNG,webp,WEBP}"
);

const carpeta = `../../assets/${serie.id}/`;
const rutasFotos = Object.keys(todasLasImagenes)
  .filter((ruta) => ruta.startsWith(carpeta))
  .sort();

const fotos = await Promise.all(
  rutasFotos.map((ruta) => todasLasImagenes[ruta]())
);
---

<Layout title={serie.data.titulo}>
  <section class="container serie-header">
    <a href="/portafolio" class="mono-label back-link">← Portafolio</a>
    <h1>{serie.data.titulo}</h1>
    <p class="serie-descripcion">{serie.data.descripcion}</p>
    <span class="mono-label">{serie.data.año}</span>
    <div class="serie-anecdota">
      <Content />
    </div>
  </section>

  <section class="container foto-grid">
    {fotos.length > 0
      ? fotos.map((foto, i) => (
          <button
            type="button"
            class="foto-item"
            data-lightbox-trigger
            data-index={i}
          >
            <Image
              src={foto.default}
              alt={`${serie.data.titulo} — fotografía ${i + 1}`}
              loading={i < 3 ? "eager" : "lazy"}
            />
            <span class="mono-label foto-numero">N.° {String(i + 1).padStart(3, "0")}</span>
          </button>
        ))
      : Array.from({ length: serie.data.fotos }).map((_, i) => (
          <div
            class="foto-placeholder"
            style={`aspect-ratio: ${i % 3 === 0 ? "4 / 3" : "3 / 4"};`}
          >
            <span class="mono-label foto-numero">N.° {String(i + 1).padStart(3, "0")}</span>
          </div>
        ))}
  </section>

  {fotos.length > 0 && (
    <div class="lightbox" data-lightbox>
      <button type="button" class="lightbox__close" data-lightbox-close aria-label="Cerrar">✕</button>
      <button type="button" class="lightbox__prev" data-lightbox-prev aria-label="Anterior">←</button>
      <img class="lightbox__img" data-lightbox-img src="" alt="" />
      <button type="button" class="lightbox__next" data-lightbox-next aria-label="Siguiente">→</button>
      <span class="mono-label lightbox__counter" data-lightbox-counter></span>
    </div>
  )}

  <style>
    .serie-header {
      padding-top: var(--space-lg);
      padding-bottom: var(--space-md);
    }
    .back-link {
      display: inline-block;
      margin-bottom: var(--space-md);
    }
    .serie-descripcion {
      max-width: 48ch;
      margin-top: var(--space-xs);
      margin-bottom: var(--space-xs);
    }
    .serie-anecdota {
      max-width: 60ch;
      margin-top: var(--space-md);
      font-size: 1rem;
      line-height: 1.75;
      color: var(--color-ink);
    }
    .serie-anecdota :global(p) {
      margin-bottom: var(--space-sm);
    }
    .foto-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      grid-auto-rows: auto;
      align-items: start;
      gap: var(--space-sm);
      padding-bottom: var(--space-xl);
    }
    .foto-item {
      .foto-numero {
      color: var(--color-safelight);
    }
      display: flex;
      flex-direction: column;
      gap: var(--space-xs);
      background: none;
      border: none;
      padding: 0;
      cursor: pointer;
      text-align: left;
      font: inherit;
      color: inherit;
    }
    .foto-item :global(img) {
      width: 100%;
      height: auto;
      display: block;
      transition: opacity 0.2s;
    }
    .foto-item:hover :global(img) {
      opacity: 0.85;
    }
    .foto-placeholder {
      width: 100%;
      background: var(--color-grey-200);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    /* Lightbox */
    .lightbox {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(27, 25, 23, 0.95);
      z-index: 100;
      align-items: center;
      justify-content: center;
    }
    .lightbox.is-open {
      display: flex;
    }
    .lightbox__img {
      max-width: 88vw;
      max-height: 82vh;
      object-fit: contain;
    }
    .lightbox__close,
    .lightbox__prev,
    .lightbox__next {
      position: absolute;
      background: none;
      border: none;
      color: var(--color-paper);
      font-size: 1.5rem;
      cursor: pointer;
      padding: var(--space-sm);
      opacity: 0.8;
      transition: opacity 0.2s;
    }
    .lightbox__close:hover,
    .lightbox__prev:hover,
    .lightbox__next:hover {
      opacity: 1;
      color: var(--color-safelight);
    }
    .lightbox__close {
      top: var(--space-sm);
      right: var(--space-sm);
    }
    .lightbox__prev {
      left: var(--space-sm);
      top: 50%;
      transform: translateY(-50%);
    }
    .lightbox__next {
      right: var(--space-sm);
      top: 50%;
      transform: translateY(-50%);
    }
    .lightbox__counter {
      position: absolute;
      bottom: var(--space-sm);
      left: 50%;
      transform: translateX(-50%);
      color: var(--color-grey-200);
    }
  </style>

  <script>
    const fotos = Array.from(
      document.querySelectorAll<HTMLButtonElement>("[data-lightbox-trigger]")
    );
    const lightbox = document.querySelector<HTMLDivElement>("[data-lightbox]");
    const imgEl = document.querySelector<HTMLImageElement>("[data-lightbox-img]");
    const counterEl = document.querySelector<HTMLSpanElement>("[data-lightbox-counter]");
    let indiceActual = 0;

    function abrir(indice: number) {
      if (!lightbox || !imgEl || !counterEl || fotos.length === 0) return;
      indiceActual = (indice + fotos.length) % fotos.length;
      const imgOriginal = fotos[indiceActual].querySelector("img");
      if (imgOriginal) {
        imgEl.src = imgOriginal.src;
        imgEl.alt = imgOriginal.alt;
      }
      counterEl.textContent = `${String(indiceActual + 1).padStart(3, "0")} / ${String(fotos.length).padStart(3, "0")}`;
      lightbox.classList.add("is-open");
      document.body.style.overflow = "hidden";
    }

    function cerrar() {
      lightbox?.classList.remove("is-open");
      document.body.style.overflow = "";
    }

    fotos.forEach((boton, i) => {
      boton.addEventListener("click", () => abrir(i));
    });

    document.querySelector("[data-lightbox-close]")?.addEventListener("click", cerrar);
    document.querySelector("[data-lightbox-prev]")?.addEventListener("click", () => abrir(indiceActual - 1));
    document.querySelector("[data-lightbox-next]")?.addEventListener("click", () => abrir(indiceActual + 1));

    lightbox?.addEventListener("click", (e) => {
      if (e.target === lightbox) cerrar();
    });

    document.addEventListener("keydown", (e) => {
      if (!lightbox?.classList.contains("is-open")) return;
      if (e.key === "Escape") cerrar();
      if (e.key === "ArrowLeft") abrir(indiceActual - 1);
      if (e.key === "ArrowRight") abrir(indiceActual + 1);
    });
  </script>
</Layout>