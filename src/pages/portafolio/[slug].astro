---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

export async function getStaticPaths() {
  const series = await getCollection("series");
  return series.map((serie) => ({
    params: { slug: serie.id },
    props: { serie },
  }));
}

const { serie } = Astro.props;
const { Content } = await render(serie);

const todasLasImagenes = import.meta.glob<{ default: ImageMetadata }>(
  "../../assets/**/*.{jpeg,jpg,JPG,JPEG,png,PNG,webp,WEBP}"
);

const carpeta = `../../assets/${serie.id}/`;
const rutasFotos = Object.keys(todasLasImagenes)
  .filter((ruta) => ruta.startsWith(carpeta))
  .sort();

const fotos = await Promise.all(
  rutasFotos.map((ruta) => todasLasImagenes[ruta]())
);
---

<Layout title={serie.data.titulo}>
  <section class="container serie-header">
    <a href="/portafolio" class="mono-label back-link">← Portafolio</a>
    <h1>{serie.data.titulo}</h1>
    <p class="serie-descripcion">{serie.data.descripcion}</p>
    <span class="mono-label">{serie.data.año}</span>
    <div class="serie-anecdota">
      <Content />
    </div>
  </section>

  <section class="container foto-grid">
    {fotos.length > 0
      ? fotos.map((foto, i) => (
          <div class="foto-item">
            <Image
              src={foto.default}
              alt={`${serie.data.titulo} — fotografía ${i + 1}`}
              loading={i < 3 ? "eager" : "lazy"}
            />
            <span class="mono-label">N.° {String(i + 1).padStart(3, "0")}</span>
          </div>
        ))
      : Array.from({ length: serie.data.fotos }).map((_, i) => (
          <div
            class="foto-placeholder"
            style={`aspect-ratio: ${i % 3 === 0 ? "4 / 3" : "3 / 4"};`}
          >
            <span class="mono-label">N.° {String(i + 1).padStart(3, "0")}</span>
          </div>
        ))}
  </section>

  <style>
    .serie-header {
      padding-top: var(--space-lg);
      padding-bottom: var(--space-md);
    }
    .back-link {
      display: inline-block;
      margin-bottom: var(--space-md);
    }
    .serie-descripcion {
      max-width: 48ch;
      margin-top: var(--space-xs);
      margin-bottom: var(--space-xs);
    }
    .serie-anecdota {
      max-width: 60ch;
      margin-top: var(--space-md);
      font-size: 1rem;
      line-height: 1.75;
      color: var(--color-ink);
    }
    .serie-anecdota :global(p) {
      margin-bottom: var(--space-sm);
    }
    .foto-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      grid-auto-rows: auto;
      align-items: start;
      gap: var(--space-sm);
      padding-bottom: var(--space-xl);
    }
    .foto-item {
      display: flex;
      flex-direction: column;
      gap: var(--space-xs);
    }
    .foto-item :global(img) {
      width: 100%;
      height: auto;
      display: block;
    }
    .foto-placeholder {
      width: 100%;
      background: var(--color-grey-200);
      display: flex;
      align-items: center;
      justify-content: center;
    }
  </style>
</Layout>